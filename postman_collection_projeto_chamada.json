          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "alunos", "{{id}}"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Verifica 204 No Content",
